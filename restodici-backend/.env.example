

# ── Environnement ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de données PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=restodici_user
DB_PASSWORD=
DB_DATABASE=restodici_db
# DB_SYNC=true        # auto-sync schéma (désactiver en prod)
# DB_LOGGING=false    # logs SQL
# DB_SSL=false        # activer en production cloud

# ── JWT ────────────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Redis (BullMQ — queues jobs) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=     # OBLIGATOIRE — Redis exige un mot de passe (docker-compose --requirepass)
# DB_PASSWORD=       # optionnel — surcharge le mot de passe PostgreSQL du docker-compose

# ── Frontend (CORS) ────────────────────────────────────────────
# Origines autorisées, séparées par des virgules. En production, SEULES
# celles-ci sont acceptées (aucun default). En dev, les localhost sont ajoutés.
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173   # compat : utilisé si CORS_ORIGINS absent

# Cookie du refresh token (HttpOnly). 'lax' si front et back partagent le domaine.
# Mettre 'none' (impose HTTPS + secure) si front et back sont sur des domaines différents.
COOKIE_SAMESITE=lax

# Clé de chiffrement des champs sensibles au repos (secret TOTP 2FA).
# Recommandé en production. À défaut, dérivée de JWT_SECRET.
TOTP_ENCRYPTION_KEY=

# ── URLs des services externes (surchargent les defaults) ──────
# NOVASEND_BASE_URL=https://business.novasend.app/v1
# NOVASEND_PAYMENTS_URL=https://api.novasend.ci/v1/payments
# FCM_SEND_URL=https://fcm.googleapis.com/fcm/send

# ── Emails — Resend (https://resend.com) ───────────────────────
RESEND_API_KEY=
RESEND_FROM=Resto d'ici <onboarding@resend.dev>

# ── Paiements — NovaSend (https://docs.novasend.app/fr) ────────
# Les deux clés sont requises pour l'auth Basic base64(key:secret)
NOVASEND_API_KEY=
NOVASEND_API_SECRET=
NOVASEND_WEBHOOK_SECRET=
# Secret HMAC du webhook CinetPay (legacy). Sans lui, le webhook est rejeté (fail-closed).
CINETPAY_WEBHOOK_SECRET=

# ── Stockage photos — AWS S3 (ou compatible : MinIO, R2) ───────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=    # URL custom si MinIO / Cloudflare R2
# AWS_S3_PUBLIC_BASE= # URL CDN publique (ex: https://cdn.restodici.com)

# ── SMS — Twilio (optionnel, fallback log si absent) ───────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Push notifications — Firebase FCM (optionnel) ─────────────
FIREBASE_SERVER_KEY=
